# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Use publishable key in ANON_KEY slot, or legacy anon key
SUPABASE_SERVICE_ROLE_KEY=
# Or new secret key (server-only, either works):
SUPABASE_SECRET_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public URL — from R2 bucket → Settings → Public Access → r2.dev subdomain
# Must match exactly, no trailing slash (e.g. https://pub-xxxxx.r2.dev)
R2_PUBLIC_URL=

# Admin — only this email can access /admin
ADMIN_EMAIL=

# Site
NEXT_PUBLIC_WHATSAPP_NUMBER=2349027548604
NEXT_PUBLIC_IG_HANDLE=azaquest
